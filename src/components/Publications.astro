---
const orcidId = "0009-0009-9008-2508";
---

<div class="orcid-wrapper">
  <div id="orcid-container" data-pagefind-ignore class="space-y-4">
    <p class="text-sec italic">
      Syncing publications&hellip; If it doesn&rsquo;t work, you can
      <a href={`https://orcid.org/${orcidId}`} class="text-ref" target="_blank">
        view on ORCID.
      </a>
    </p>
  </div>
</div>

<script is:inline define:vars={{ orcidId }}>
  (async () => {
    const container = document.getElementById("orcid-container");
    try {
      const res = await fetch(`https://pub.orcid.org/v3.0/${orcidId}/works`, {
        headers: { Accept: "application/json" },
      });
      const data = await res.json();

      if (!data.group?.length) {
        container.innerHTML = `
          <p class="text-sec italic">No public works found.</p>
        `;
        return;
      }

      const html = data.group
        .map((item, index) => {
          const w = item["work-summary"][0];
          const title = w.title?.title?.value || "Untitled";
          const year = w["publication-date"]?.year?.value || "n.d.";
          const journal = w["journal-title"]?.value || "";
          const doiId = w["external-ids"]?.["external-id"]?.find(
            (i) => i["external-id-type"] === "doi",
          );
          const url = doiId
            ? `https://doi.org/${doiId["external-id-value"]}`
            : null;

          const bgColor = index % 2 === 0 ? "bg-white" : "bg-quat/20";

          return `
          <a ${url ? `href="${url}" target="_blank"` : ""} class="group block !no-underline">
            <div class="pl-8 pr-8 p-4 ${bgColor} w-full border-1 border-quat/40">
              <div class="flex flex-col">
                <div class="text-base text-main group-hover:text-ref mb-4 leading-relaxed transform transition-all duration-300 group-hover:translate-x-1">
                  ${title}
                </div>
                <div class="text-xs text-sec flex gap-4">
                  <span>${year}</span>
                  ${journal ? `<span>|</span><span class="italic">${journal}</span>` : ""}
                </div>
              </div>
            </div>
          </a>
        `;
        })
        .join("");

      container.removeAttribute("data-pagefind-ignore");
      container.innerHTML = html;
    } catch (e) {
      container.innerHTML = `
        <p class="text-sec italic">
          Sync failed, you may 
          <a href="https://orcid.org/${orcidId}" class="text-ref" target="_blank">
            refer to ORCID.
          </a>
        </p>
      `;
    }
  })();
</script>
